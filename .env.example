# PlaceOS X Environment Variables

# MongoDB Configuration (Required)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/placeos-x

# JWT Configuration (Required for authentication)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Optional: Public variables
NEXT_PUBLIC_APP_NAME=PlaceOS X
NEXT_PUBLIC_APP_VERSION=1.0.0

# Instructions:
# 1. Replace MONGODB_URI with your MongoDB connection string
#    - Get this from MongoDB Atlas or your MongoDB provider
#    - Format: mongodb+srv://username:password@cluster.mongodb.net/database-name
# 
# 2. Set JWT_SECRET to a strong random string
#    - Use: openssl rand -base64 32
#    - Or generate at: https://generateme.org/crypto/SHA256
